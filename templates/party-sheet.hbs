<form class="{{cssClass}} flexcol" autocomplete="off">

  {{!-- Header: matches SD-header pattern --}}
  <header class="SD-header flex0">
    <img
      class="portrait"
      src="{{actor.img}}"
      data-edit="img"
      data-tooltip="{{actor.name}}"
      height="110"
      width="110"
    />
    <div class="shadowdark-logo">
      <span>ShadowDark</span>
    </div>
    <div class="SD-title">
      <input
        name="name"
        type="text"
        value="{{actor.name}}"
        placeholder="{{localize 'PARTY.sheet.name'}}"
      />
    </div>
  </header>

  {{!-- Navigation --}}
  <nav class="SD-nav flex0" data-group="primary">
    <a class="navigation-tab active" data-tab="tab-members">
      {{localize "PARTY.tab.members"}}
    </a>
    <a class="navigation-tab" data-tab="tab-inventory">
      {{localize "PARTY.tab.inventory"}}
    </a>
  </nav>

  {{!-- Content --}}
  <section class="SD-content-body flex1">

    {{!-- Members Tab --}}
    <section class="tab tab-members" data-group="primary" data-tab="tab-members">

      {{#if isEmpty}}
      <div class="party-empty-hint">
        <p><i class="fas fa-users"></i> {{localize "PARTY.sheet.dropHint"}}</p>
      </div>
      {{/if}}

    {{!-- Characters Section --}}
    {{#if characters.length}}
    <div class="SD-box party-box">
      <div class="header">
        <label><i class="fas fa-shield-alt"></i> {{localize "PARTY.sheet.characters"}}</label>
        <span></span>
      </div>
      <div class="content">
        <ul class="SD-list">
          <li class="list-header">
            <span class="member-img-col"></span>
            <span class="item-name">{{localize "PARTY.column.name"}}</span>
            <span class="member-field">{{localize "PARTY.column.ancestry"}}</span>
            <span class="member-field">{{localize "PARTY.column.class"}}</span>
            <span class="member-stat">{{localize "PARTY.column.level"}}</span>
            <span class="member-stat">{{localize "PARTY.column.slots"}}</span>
            {{#if editable}}<span class="member-actions"></span>{{/if}}
          </li>
          {{#each characters}}
          <li data-uuid="{{this.uuid}}" class="{{#if this.missing}}missing{{/if}}">
            {{#if this.missing}}
              <span class="member-img-col"><i class="fas fa-exclamation-triangle"></i></span>
              <span class="item-name">{{this.name}}</span>
            {{else}}
              <span class="member-img-col">
                <img src="{{this.img}}" class="member-img" />
              </span>
              <span class="item-name">
                <a data-action="open-sheet">{{this.name}}</a>
              </span>
              <span class="member-field">{{this.ancestry}}</span>
              <span class="member-field">{{this.className}}</span>
              <span class="member-stat">{{this.level}}</span>
              <span class="member-stat">
                {{#if this.isPlayer}}
                  {{this.slotsUsed}}/{{this.slotsTotal}}
                {{else}}
                  —
                {{/if}}
              </span>
            {{/if}}
            {{#if @root.editable}}
            <span class="member-actions">
              <a data-action="toggle-role" title="{{localize 'PARTY.actions.toggleRole'}}"><i class="fas fa-exchange-alt"></i></a>
              <a data-action="remove-member" title="{{localize 'PARTY.actions.remove'}}"><i class="fas fa-trash"></i></a>
            </span>
            {{/if}}
          </li>
          {{/each}}
        </ul>
      </div>
    </div>
    {{/if}}

    {{!-- Followers Section --}}
    {{#if followers.length}}
    <div class="SD-box party-box">
      <div class="header">
        <label><i class="fas fa-hiking"></i> {{localize "PARTY.sheet.followers"}}</label>
        <span></span>
      </div>
      <div class="content">
        <ul class="SD-list">
          <li class="list-header">
            <span class="member-img-col"></span>
            <span class="item-name">{{localize "PARTY.column.name"}}</span>
            <span class="member-field">{{localize "PARTY.column.ancestry"}}</span>
            <span class="member-field">{{localize "PARTY.column.class"}}</span>
            <span class="member-stat">{{localize "PARTY.column.level"}}</span>
            <span class="member-stat">{{localize "PARTY.column.slots"}}</span>
            {{#if editable}}<span class="member-actions"></span>{{/if}}
          </li>
          {{#each followers}}
          <li data-uuid="{{this.uuid}}" class="{{#if this.missing}}missing{{/if}}">
            {{#if this.missing}}
              <span class="member-img-col"><i class="fas fa-exclamation-triangle"></i></span>
              <span class="item-name">{{this.name}}</span>
            {{else}}
              <span class="member-img-col">
                <img src="{{this.img}}" class="member-img" />
              </span>
              <span class="item-name">
                <a data-action="open-sheet">{{this.name}}</a>
              </span>
              <span class="member-field">{{this.ancestry}}</span>
              <span class="member-field">{{this.className}}</span>
              <span class="member-stat">{{this.level}}</span>
              <span class="member-stat">
                {{#if this.isPlayer}}
                  {{this.slotsUsed}}/{{this.slotsTotal}}
                {{else}}
                  —
                {{/if}}
              </span>
            {{/if}}
            {{#if @root.editable}}
            <span class="member-actions">
              <a data-action="toggle-role" title="{{localize 'PARTY.actions.toggleRole'}}"><i class="fas fa-exchange-alt"></i></a>
              <a data-action="remove-member" title="{{localize 'PARTY.actions.remove'}}"><i class="fas fa-trash"></i></a>
            </span>
            {{/if}}
          </li>
          {{/each}}
        </ul>
      </div>
    </div>
    {{/if}}

    </section>

    {{!-- Inventory Tab --}}
    <section class="tab tab-inventory" data-group="primary" data-tab="tab-inventory">

      {{#unless hasInventory}}
      <div class="party-empty-hint">
        <p><i class="fas fa-box-open"></i> {{localize "PARTY.inventory.empty"}}</p>
      </div>
      {{/unless}}

      {{#each inventoryGroups}}
      <div class="SD-box party-box">
        <div class="header">
          <label>{{this.label}}</label>
          <span></span>
        </div>
        <div class="content">
          <ul class="SD-list">
            <li class="list-header">
              <span class="inv-img-col"></span>
              <span class="item-name">{{localize "PARTY.column.name"}}</span>
              <span class="inv-owners">{{localize "PARTY.column.carriedBy"}}</span>
              <span class="inv-qty">{{localize "PARTY.column.qty"}}</span>
            </li>
            {{#each this.items}}
            <li>
              <span class="inv-img-col">
                <img src="{{this.img}}" class="member-img" />
              </span>
              <span class="item-name">{{this.name}}</span>
              <span class="inv-owners">
                {{#each this.owners}}{{#unless @first}}, {{/unless}}{{this.name}} ({{this.quantity}}){{/each}}
              </span>
              <span class="inv-qty">{{this.totalQuantity}}</span>
            </li>
            {{/each}}
          </ul>
        </div>
      </div>
      {{/each}}

    </section>

  </section>

</form>
