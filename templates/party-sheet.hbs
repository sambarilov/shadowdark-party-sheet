<form class="party-sheet flexcol" autocomplete="off">

  {{!-- Header --}}
  <header class="party-header flexrow">
    <img src="{{actor.img}}" class="party-portrait" title="{{actor.name}}" />
    <div class="party-header-info flexcol">
      <input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'PARTY.sheet.name'}}" {{#unless editable}}disabled{{/unless}} />
    </div>
  </header>

  {{!-- Drop Zone --}}
  <section class="party-drop-zone">

    {{#if isEmpty}}
    <div class="party-empty-hint">
      <p><i class="fas fa-users"></i> {{localize "PARTY.sheet.dropHint"}}</p>
    </div>
    {{/if}}

    {{!-- Characters Section --}}
    {{#if characters.length}}
    <div class="party-section">
      <h2 class="party-section-header">
        <i class="fas fa-shield-alt"></i> {{localize "PARTY.sheet.characters"}}
      </h2>
      <table class="party-member-table">
        <thead>
          <tr>
            <th class="col-img"></th>
            <th class="col-name">{{localize "PARTY.column.name"}}</th>
            <th class="col-ancestry">{{localize "PARTY.column.ancestry"}}</th>
            <th class="col-class">{{localize "PARTY.column.class"}}</th>
            <th class="col-level">{{localize "PARTY.column.level"}}</th>
            <th class="col-slots">{{localize "PARTY.column.slots"}}</th>
            {{#if editable}}<th class="col-actions">{{localize "PARTY.column.actions"}}</th>{{/if}}
          </tr>
        </thead>
        <tbody>
          {{#each characters}}
          <tr class="party-member-row {{#if this.missing}}missing{{/if}}" data-uuid="{{this.uuid}}">
            {{#if this.missing}}
              <td class="col-img"><i class="fas fa-exclamation-triangle"></i></td>
              <td class="col-name" colspan="5">{{this.name}}</td>
            {{else}}
              <td class="col-img"><img src="{{this.img}}" class="member-img" /></td>
              <td class="col-name"><a data-action="open-sheet">{{this.name}}</a></td>
              <td class="col-ancestry">{{this.ancestry}}</td>
              <td class="col-class">{{this.className}}</td>
              <td class="col-level">{{this.level}}</td>
              <td class="col-slots">
                {{#if this.isPlayer}}
                  {{this.slotsUsed}} / {{this.slotsTotal}}
                {{else}}
                  —
                {{/if}}
              </td>
            {{/if}}
            {{#if @root.editable}}
            <td class="col-actions">
              <a data-action="toggle-role" title="{{localize 'PARTY.actions.toggleRole'}}"><i class="fas fa-exchange-alt"></i></a>
              <a data-action="remove-member" title="{{localize 'PARTY.actions.remove'}}"><i class="fas fa-trash"></i></a>
            </td>
            {{/if}}
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}

    {{!-- Followers Section --}}
    {{#if followers.length}}
    <div class="party-section">
      <h2 class="party-section-header">
        <i class="fas fa-hiking"></i> {{localize "PARTY.sheet.followers"}}
      </h2>
      <table class="party-member-table">
        <thead>
          <tr>
            <th class="col-img"></th>
            <th class="col-name">{{localize "PARTY.column.name"}}</th>
            <th class="col-ancestry">{{localize "PARTY.column.ancestry"}}</th>
            <th class="col-class">{{localize "PARTY.column.class"}}</th>
            <th class="col-level">{{localize "PARTY.column.level"}}</th>
            <th class="col-slots">{{localize "PARTY.column.slots"}}</th>
            {{#if editable}}<th class="col-actions">{{localize "PARTY.column.actions"}}</th>{{/if}}
          </tr>
        </thead>
        <tbody>
          {{#each followers}}
          <tr class="party-member-row {{#if this.missing}}missing{{/if}}" data-uuid="{{this.uuid}}">
            {{#if this.missing}}
              <td class="col-img"><i class="fas fa-exclamation-triangle"></i></td>
              <td class="col-name" colspan="5">{{this.name}}</td>
            {{else}}
              <td class="col-img"><img src="{{this.img}}" class="member-img" /></td>
              <td class="col-name"><a data-action="open-sheet">{{this.name}}</a></td>
              <td class="col-ancestry">{{this.ancestry}}</td>
              <td class="col-class">{{this.className}}</td>
              <td class="col-level">{{this.level}}</td>
              <td class="col-slots">
                {{#if this.isPlayer}}
                  {{this.slotsUsed}} / {{this.slotsTotal}}
                {{else}}
                  —
                {{/if}}
              </td>
            {{/if}}
            {{#if @root.editable}}
            <td class="col-actions">
              <a data-action="toggle-role" title="{{localize 'PARTY.actions.toggleRole'}}"><i class="fas fa-exchange-alt"></i></a>
              <a data-action="remove-member" title="{{localize 'PARTY.actions.remove'}}"><i class="fas fa-trash"></i></a>
            </td>
            {{/if}}
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}

  </section>

</form>
